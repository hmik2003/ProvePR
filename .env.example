# Copy this file to `.env` and fill in values.
# NEVER commit your real `.env` file.

# --- Required starting Sprint 2 (GitHub + Jira) ---
# GitHub: prefer a fine-grained PAT — Pull requests (read) + Issues (read/write for PR comments).
# Do NOT grant admin or workflow edit unless you intentionally need it.
GITHUB_TOKEN=

# Jira: ProvePR code is READ-ONLY (GET issue only).
# Prefer a dedicated bot user with Browse/view only — no Create/Edit issues.
# See SECURITY.md
JIRA_SERVER_URL=https://your-company.atlassian.net
JIRA_EMAIL=provepr-bot@company.com
JIRA_API_TOKEN=

# --- Required starting Sprint 4 (Gemini / Hermes) ---
GOOGLE_API_KEY=
# Optional alias:
# GEMINI_API_KEY=

# Optional: pin model (default gemini-flash-lite-latest)
# GEMINI_MODEL=gemini-flash-lite-latest

# Hermes project plugins (ProvePR tools under .hermes/plugins/provepr)
# HERMES_ENABLE_PROJECT_PLUGINS=1

# --- Sprint 5+ Slack: personal DM only (recommended for now) ---
# Create a Slack app → Bot token scopes: chat:write, im:write
# Install to workspace, then set:
SLACK_BOT_TOKEN=
SLACK_DM_USER_ID=
# Legacy channel webhook (optional; not used when bot DM is configured):
# SLACK_WEBHOOK_URL=

# --- Sprint 6 HTTP / Docker / Cloud Run ---
# PROVEPR_TRIGGER_SECRET=change-me-long-random
# Local:
# PROVEPR_HTTP_HOST=127.0.0.1
# PROVEPR_HTTP_PORT=8080
# Cloud Run / Docker set PORT automatically; bind 0.0.0.0 when PORT is set.

# --- Optional local test targets ---
GITHUB_TEST_REPO=hmik2003/ProvePR
GITHUB_TEST_PR_NUMBER=1
# JIRA_TEST_TICKET=ABC-42
