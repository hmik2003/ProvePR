# Copy this file to `.env` and fill in values.
# NEVER commit your real `.env` file.

# --- Required starting Sprint 2 (GitHub + Jira) ---
GITHUB_TOKEN=
JIRA_SERVER_URL=https://your-company.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=

# --- Required starting Sprint 3 (Hermes + Gemini) ---
GOOGLE_API_KEY=
# Optional alias Hermes also accepts:
# GEMINI_API_KEY=

# Optional: pin model (default gemini-flash-lite-latest — cheapest working Flash alias)
# GEMINI_MODEL=gemini-flash-lite-latest

# --- Required starting Sprint 4 (outputs) ---
SLACK_WEBHOOK_URL=

# --- Optional local test targets (Sprint 2 / 3) ---
# GitHub sample repo + PR (Sprint 3 fetch)
GITHUB_TEST_REPO=hmik2003/ProvePR
GITHUB_TEST_PR_NUMBER=1
# Any real Jira issue key you can open in the browser (not a secret):
# JIRA_TEST_TICKET=ABC-42
